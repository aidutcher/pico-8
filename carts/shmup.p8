pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- cart file

-- includes
#include ../include/shmup_ship.lua
#include ../include/shmup_weapons.lua
-- init gets called once
-- when program starts
function _init()
	-- clear the screen with
	-- black background
	cls(0)
	make_ship()
	make_jets()
	blts={}
end

-- update is for gameplay funcs
-- hard 30 fps
function _update()
	ship.sprite=1
	move_ship()
	upd_jets()
	add_blt()
	upd_blts()
end

-- draw gets called when a new
-- frame gets drawn to screen
-- 30 fps
function _draw()
	-- clear screen, otherwise
	-- everything drawn persists
	cls(0)
	draw_ship()
	draw_jets()
	draw_blts()
end
